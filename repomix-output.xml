    @pytest.mark.asyncio
    async def test_sampling_count_mode(self):
        node = _make_node()
        runfile = Runfile(workflow=[node])
        runfile.sampling.mode = "count"
        runfile.sampling.value = 2
        engine = _mock_engine()
