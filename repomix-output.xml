```python
class SkillVault:
    def __init__(self, storage_path: str):
        self.path = Path(storage_path)

    async def solidify(self, task_trace: TaskTrace, original_runfile: Runfile) -> str:
        """将执行轨迹提炼为永久技能"""
        # 1. 找到表现最好的 Prompt 版本
        best_version = self._analyze_best_prompt(task_trace)
        
        # 2. 构建精简版 Runfile
        solid_runfile = original_runfile.copy()
        solid_runfile.fingerprint.locked_prompt = best_version.template
        
        # 3. 存储为 .trs (JSON/YAML)
        skill_id = f"skill_{int(time.time())}"
        with open(self.path / f"{skill_id}.trs", "w") as f:
            f.write(solid_runfile.json())
            
        return skill_id

